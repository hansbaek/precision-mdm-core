# API
NODE_ENV=development
API_PORT=4000

# Oracle Database 19c
# Thin mode is used by default by node-oracledb; no Oracle Client install is required.
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=xepdb1
DB_USERNAME=app_user
DB_PASSWORD=change_me
# DB_SID=ORCLCDB
# DB_CONNECT_STRING=localhost:1521/xepdb1

# Pool / logging
DB_POOL_SIZE=10
DB_LOGGING=false
