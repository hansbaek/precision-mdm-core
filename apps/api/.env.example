# API
NODE_ENV=development
API_PORT=4000

# 허용할 프런트엔드 Origin(콤마 구분). 운영에서는 반드시 설정할 것.
# 미설정 시: 개발(NODE_ENV!=production)은 전체 허용, 운영은 전체 차단.
# CORS_ORIGINS=https://mdm.example.com,https://admin.example.com

# Oracle Database 19c
# Thin mode is used by default by node-oracledb; no Oracle Client install is required.
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=xepdb1
DB_USERNAME=app_user
DB_PASSWORD=change_me
# DB_SID=ORCLCDB
# DB_CONNECT_STRING=localhost:1521/xepdb1

# Pool / logging
DB_POOL_SIZE=10
DB_LOGGING=false

# Auth (JWT)
# JWT_SECRET must be a long random string in production.
JWT_SECRET=change_me_to_a_long_random_secret
# 액세스 토큰은 단기(기본 15m), 리프레시 토큰은 장기(기본 14d).
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
# Authentication source: 'local' (TMDM_USER + bcrypt) or 'sso' (groupware, future).
AUTH_PROVIDER=local

# Initial admin password — only used by scripts/seed-auth.cjs when creating the
# 'admin' account for the first time. A command-line value overrides this.
# ADMIN_PASSWORD=change_me_strong_password
